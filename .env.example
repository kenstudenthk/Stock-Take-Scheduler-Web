# Stock Take Scheduler - Environment Variables
# Copy this file to .env and fill in your values

# Microsoft Graph 自动刷新配置
VITE_AUTO_REFRESH_CLIENT_ID=your-client-id-here
VITE_AUTO_REFRESH_CLIENT_SECRET=your-client-secret-here
VITE_AUTO_REFRESH_TENANT_ID=your-tenant-id-here

# SharePoint Configuration
# Site GUID (hostname,siteCollectionId,webId) 備用格式，需要時可切換使用：
# pccw0.sharepoint.com,5e50edc1-194f-4f74-880f-991634b854e7,9c0019c8-7e0b-4b28-9312-ccd732f7c5d9
VITE_SHAREPOINT_SITE_ID=pccw0.sharepoint.com:/sites/MX_Assets_Audit:
VITE_SHOP_LIST_ID=142ee1aa-c0d0-4846-91f9-0b9b8a6c0e83
VITE_MEMBER_LIST_ID=5239aa9c-32a3-4372-b6ef-01f117bafb98
VITE_INVENTORY_LIST_ID=4febed7a-6b09-42c5-8ff9-9ae6331faeb2
VITE_ERROR_LOG_LIST_ID=2bb7f712-dcaa-4b7c-aaa9-0055d32afffc
VITE_TIME_CARD_LIST_ID=47e29fdc-ab5b-4cce-873f-9d81a7f17cd2

# AMap Configuration (for map features)
VITE_AMAP_API_KEY=your_amap_api_key
VITE_AMAP_SECURITY_CODE=your_amap_security_code

# Optional: Gemini API (if using AI features)
GEMINI_API_KEY=your_gemini_api_key

# Token Settings
VITE_TOKEN_WARNING_MINUTES=45
